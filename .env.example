# ── Nautobot (Source of Truth) ─────────────────────────────────────────────
NAUTOBOT_URL=http://localhost:8080
NAUTOBOT_TOKEN=your-nautobot-api-token-here
NAUTOBOT_VERIFY_SSL=false
NAUTOBOT_TIMEOUT=30

# ── Device Credentials ─────────────────────────────────────────────────────
DEVICE_USERNAME=admin
DEVICE_PASSWORD=changeme

# ── Platform Behaviour ─────────────────────────────────────────────────────
ENVIRONMENT=lab
DRY_RUN=true
LOG_LEVEL=INFO
ROLLBACK_ON_FAILURE=true
DRIFT_DETECTION_ENABLED=true

# ── Scrapli Transport ──────────────────────────────────────────────────────
SCRAPLI_PLATFORM=cisco_iosxe
SCRAPLI_AUTH_STRICT_KEY=false
SCRAPLI_TIMEOUT_SOCKET=15
SCRAPLI_TIMEOUT_TRANSPORT=30
SCRAPLI_TIMEOUT_OPS=60

# ── Nornir Runner ──────────────────────────────────────────────────────────
NORNIR_NUM_WORKERS=10
NORNIR_RUNNER_PLUGIN=threaded

# ── Prometheus ─────────────────────────────────────────────────────────────
PROMETHEUS_PUSHGATEWAY_URL=http://localhost:9091
PROMETHEUS_JOB_NAME=network_automation
PROMETHEUS_PUSH_ENABLED=false

# ── AI / Ollama ────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3
OLLAMA_TIMEOUT=120
AI_ENABLED=false
