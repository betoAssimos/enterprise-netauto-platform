{#
  automation/templates/definitions/ospf/process.j2
  Renders OSPF process configuration for Cisco IOS-XE (c8000v).
  Required context variables:
    ospf_process  (int)  : OSPF process ID
    ospf_router_id (str) : Router-ID
    ospf_networks (list) : List of {network, wildcard, area} dicts
  Optional:
    ospf_redistribute_bgp (int) : BGP AS to redistribute into OSPF
#}
router ospf {{ ospf_process }}
 router-id {{ ospf_router_id }}
{% if ospf_redistribute_bgp is defined %}
 redistribute bgp {{ ospf_redistribute_bgp }}
{% endif %}
{% for net in ospf_networks %}
 network {{ net.network }} {{ net.wildcard }} area {{ net.area }}
{% endfor %}