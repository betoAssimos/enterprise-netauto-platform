{#
  automation/templates/definitions/services/syslog_eos.j2
  Renders syslog configuration for Arista EOS (cEOS).

  Required context variables:
    syslog_server   (str) : Syslog server IP address
    syslog_trap     (str) : Severity level (e.g. "informational")
    syslog_source   (str) : Source interface for syslog messages
#}
logging host {{ syslog_server }}
logging trap {{ syslog_trap }}
logging source-interface {{ syslog_source }}