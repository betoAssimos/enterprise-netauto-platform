{#
  automation/templates/definitions/interfaces/layer3.j2

  Cisco IOS XE — Layer 3 interface configuration.

  Context variable:
    interfaces (list): each item is a dict from custom_fields.interfaces

  Required per interface:
    name        (str): interface name, e.g. GigabitEthernet2
    ip_address  (str): CIDR notation, e.g. 10.0.0.1/30
    description (str): interface description

  Optional per interface:
    nat_role      (str) : "inside" or "outside"
    ospf_area     (str) : OSPF area, e.g. "0"
    ospf_process  (str) : OSPF process ID, default "1"
    ospf_network  (str) : OSPF network type, e.g. point-to-point
    shutdown      (bool): admin-down state, default false
    mtu           (int) : MTU override
#}
{% for iface in interfaces %}
!
! -- {{ iface.description | default(iface.name) }}
interface {{ iface.name }}
 description {{ iface.description | default("no-description") }}
 ip address {{ iface.ip_address | ipaddr_to_netmask }}
{% if iface.nat_role is defined %}
 ip nat {{ iface.nat_role }}
{% endif %}
{% if iface.mtu is defined %}
 ip mtu {{ iface.mtu }}
{% endif %}
{% if iface.ospf_area is defined %}
 ip ospf {{ iface.ospf_process | default("1") }} area {{ iface.ospf_area }}
{% endif %}
{% if iface.ospf_network is defined %}
 ip ospf network {{ iface.ospf_network }}
{% endif %}
{% if iface.shutdown | default(false) %}
 shutdown
{% else %}
 no shutdown
{% endif %}
{% endfor %}