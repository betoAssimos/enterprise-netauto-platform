{#
  automation/templates/definitions/ospf/process_eos.j2

  Arista EOS — OSPF process configuration.

  Interface-level OSPF participation (ip ospf area X) is configured
  in the interface deploy workflow via layer3_eos.j2.
  This template only configures the OSPF process and router-id.

  Required context variables:
    ospf_process   (int) : OSPF process ID
    ospf_router_id (str) : Router-ID
#}
router ospf {{ ospf_process }}
   router-id {{ ospf_router_id }}
   passive-interface default
   no passive-interface Ethernet1
   no passive-interface Ethernet2